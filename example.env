RECIPIENTS_EMAILS=["recipient1@example.com", "recipient2@example.com"]
SCRAPPER_API_KEY="your_scraperapi_key_here"

# Resend Email API (used to send the notification emails)
# Create a key at https://resend.com and verify a sending domain.
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_WEBHOOK_SECRET=""

# XE uses the standard ScraperAPI plan. Spitogatos is reached for free via a local
# headless browser (Playwright), so these premium toggles are no longer required.
SCRAPERAPI_PREMIUM=false
SCRAPERAPI_ULTRA_PREMIUM=false

# How often the bot re-checks for new listings (in minutes)
SEARCH_INTERVAL_MINUTES=30


#XE CONFIG
MINIMUM_PRICE=300
MAXIMUM_PRICE=550
MINIMUM_SIZE=40
MAXIMUM_SIZE=
MINIMUM_BEDROOMS=1
MAXIMUM_BEDROOMS=
MINIMUM_LEVEL=L0
MAXIMUM_LEVEL=L0
SORTING=create_desc

